# OIDC client credentials for token generation.
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit credentials.

# FTS3 job submission role
FTS_CLIENT_ID=
FTS_CLIENT_SECRET=

# Source storage read role
SRC_CLIENT_ID=
SRC_CLIENT_SECRET=

# Destination storage write role
DST_CLIENT_ID=
DST_CLIENT_SECRET=
